# Database
DATABASE_URL=postgresql://gymaccess:gymaccess@postgres:5432/gymaccess

# Stripe
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=
# Platform fee percentage taken from each gym member payment via Stripe Connect (0-100)
PLATFORM_FEE_PERCENT=5
# GymAccess SaaS subscription pricing (in NOK)
SAAS_MONTHLY_PRICE=299
SAAS_YEARLY_PRICE=2490

# SMTP (email notifications)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gymaccess.app

# igloohome Direct API (free tier — no Seam required)
# Get credentials from https://access.igloocompany.co/api-access (iglooaccess dashboard)
IGLOOHOME_CLIENT_ID=your_igloohome_client_id_here
IGLOOHOME_CLIENT_SECRET=your_igloohome_client_secret_here
IGLOOHOME_TOKEN_URL=https://auth.igloohome.co/oauth2/token
IGLOOHOME_API_URL=https://api.igloodeveloper.co/igloohome

# Seam (igloohome smart lock integration — paid add-on)
# Get your API key from https://console.seam.co
SEAM_API_KEY=seam_test_placeholder_use_real_key
# Set SEAM_MOCK=true for development/testing without a real Seam account
SEAM_MOCK=false
# Monthly price in cents for the Seam add-on (e.g. 14900 = 149 NOK/month)
SEAM_ADDON_PRICE=14900

# Access control
ACCESS_CODE_LENGTH=4
DEFAULT_MEMBERSHIP_PRICE=299

# API
API_PORT=8080
API_SECRET=change-this-to-a-random-secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis (optional)
REDIS_URL=redis://redis:6379

# Node environment
NODE_ENV=development
