# Database
DATABASE_URL=postgresql://gymaccess:gymaccess@postgres:5432/gymaccess

# Stripe
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=
# Platform fee percentages per plan (applied on top of Stripe processing fees)
STARTER_FEE_PERCENT=3
PRO_FEE_PERCENT=1
# GymAccess SaaS subscription pricing (in NOK)
SAAS_MONTHLY_PRICE=299
SAAS_YEARLY_PRICE=2490

# SMTP (email notifications)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gymaccess.app

# igloohome Direct API (free tier — no Seam required)
# igloohome credentials are configured per-gym in the admin Settings page
IGLOOHOME_TOKEN_URL=https://auth.igloohome.co/oauth2/token
IGLOOHOME_API_URL=https://api.igloodeveloper.co/igloohome

# Access control
ACCESS_CODE_LENGTH=4
DEFAULT_MEMBERSHIP_PRICE=299

# API
API_PORT=8080
API_SECRET=change-this-to-a-random-secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis (optional)
REDIS_URL=redis://redis:6379

# Node environment
NODE_ENV=development
